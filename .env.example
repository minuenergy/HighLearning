# Local Supabase
# 실제 로컬 키는 `python3 scripts/sync_local_supabase_env.py --start` 로 덮어쓰는 것을 권장합니다.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Backend
NEXT_PUBLIC_API_URL=http://localhost:8000
DOCUMENT_PARSER=auto
PADDLEOCR_LANG=korean
PADDLEOCR_DEVICE=cpu
PADDLEOCR_USE_DOC_ORIENTATION_CLASSIFY=false
PADDLEOCR_USE_DOC_UNWARPING=false
PADDLEOCR_USE_TEXTLINE_ORIENTATION=false
VISION_OCR_LANGUAGES=ko-KR,en-US
VISION_OCR_FAST=false
VISION_OCR_PDF_DPI=160
